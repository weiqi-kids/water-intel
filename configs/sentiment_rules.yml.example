# 情緒分析規則範例
# 複製此檔案為 sentiment_rules.yml 並依產業修改

# 正面詞彙
positive:
  strong:  # 分數 +1.0
    - "突破"
    - "領先"
    - "大幅成長"
    - "超越預期"
    - "創新高"
    - "record"
    - "breakthrough"
    - "leading"
    - "outperform"
    - "beat expectations"

  moderate:  # 分數 +0.5
    - "成長"
    - "增加"
    - "擴大"
    - "提升"
    - "optimistic"
    - "growth"
    - "increase"
    - "expand"
    - "improve"
    - "strong demand"

# 負面詞彙
negative:
  strong:  # 分數 -1.0
    - "虧損"
    - "下滑"
    - "衰退"
    - "警告"
    - "暴跌"
    - "loss"
    - "decline"
    - "warning"
    - "plunge"
    - "miss expectations"

  moderate:  # 分數 -0.5
    - "減少"
    - "放緩"
    - "挑戰"
    - "疲軟"
    - "concerns"
    - "slow"
    - "weak"
    - "challenging"
    - "uncertainty"
    - "pressure"

# 否定詞設定
negation:
  words:
    - "否認"
    - "取消"
    - "延後"
    - "不會"
    - "沒有"
    - "未"
    - "非"
    - "deny"
    - "cancel"
    - "postpone"
    - "not"
    - "no"
    - "won't"
    - "didn't"
    - "hasn't"
    - "without"
  # 否定詞的影響範圍（前後幾個詞）
  window: 5

# 計算方式說明：
# 1. 累加所有匹配詞的分數
# 2. 如果正面詞前後 window 範圍內有否定詞，則該詞分數反轉
# 3. 取平均值並正規化到 [-1, 1]
