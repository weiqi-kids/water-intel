# 異常偵測規則範例
# 複製此檔案為 anomaly_rules.yml 並依產業修改

anomaly_detection:

  # 資料不足時不觸發異常
  # 避免因為剛開始收集資料就誤報
  minimum_data_requirements:
    7d_avg: 5      # 至少要有 5 天資料才計算 7 日均值
    30d_avg: 20    # 至少要有 20 天資料才計算 30 日均值
    yoy: 300       # 至少要有 300 天資料才計算去年同期

  # 各類異常的觸發閾值
  thresholds:
    # 新聞量暴增
    volume_spike:
      vs_7d_pct: 100      # 較 7 日均值增加 100% 以上
      vs_30d_pct: 80      # 較 30 日均值增加 80% 以上
      vs_yoy_pct: 150     # 較去年同期增加 150% 以上
      min_absolute: 3     # 最小絕對數量（避免 1→3 就觸發）

    # 情緒急轉
    sentiment_shift:
      delta_7d: 0.5       # 較 7 日均值變化 0.5 以上
      delta_30d: 0.4      # 較 30 日均值變化 0.4 以上
      min_events: 3       # 最少要有 3 則新聞才計算情緒

    # 主題重新出現
    topic_resurface:
      min_silent_days: 14 # 至少沉寂 14 天才算「重新出現」
      min_events: 2       # 至少 2 則才算「出現」

  # 異常優先級（用於排序，數字越小越優先）
  priority:
    volume_spike: 1
    sentiment_shift: 2
    topic_resurface: 3
